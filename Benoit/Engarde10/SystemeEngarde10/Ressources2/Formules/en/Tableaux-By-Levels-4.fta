 [hasard_par_2 non]
 [qualifies 0]
 [nom "A"]
 [nom_etendu "tableau direct"]
 [nom_tableaux "tableau of ^1"]
 [origine1 "classement_initial 1-1000"]
 [tableaux_par_niveau 4]
 [cle 1]
}
