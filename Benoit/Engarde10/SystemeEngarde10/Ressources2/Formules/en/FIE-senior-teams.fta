; ===========================

{[classe multi_affichage]
 [nom "T32"]
 [nom_etendu "Tableau 32"]
 [liste_tab_a_imp ( ((a32 a32)) )]
 [max_min (32 17)]
 [global vrai]
 [cle 1]
}

{[classe multi_affichage]
 [nom "T64-32"]
 [nom_etendu "Tableaux 64-32"]
 [liste_tab_a_imp ( ((a64 a32)) )]
 [max_min (64 33)]
 [global vrai]
 [cle 2]
}

{[classe multi_affichage]
 [nom "T128-32"]
 [nom_etendu "Tableaux 128-32"]
 [liste_tab_a_imp ( ((a128 a32)) )]
 [max_min (128 65)]
 [global vrai]
 [cle 3]
}

{[classe multi_affichage]
 [nom "T16ALL"]
 [nom_etendu "All matches from T16"]
 [liste_tab_a_imp ( ((a16 a2 b8 b2) (h2 e2)) ((c4 c2 d2 d2)) ((f4 f2 g2 g2)) )]
 [global vrai]
 [cle 4]
}

{[classe multi_affichage]
 [nom "T16_et_battus"]
 [nom_etendu "Tableau 16 and losers"]
 [liste_tab_a_imp ( ((a16 a2 b8 b2) (h2 e2)) )]
 [cle 5]
}

{[classe multi_affichage]
 [nom "T13-16_5-8"]
 [nom_etendu "Tableaux 13-16 and 5-8"]
 [liste_tab_a_imp ( ((c4 c2 d2 d2)) ((f4 f2 g2 g2)) )]
 [cle 6]
}

{[classe fichier_web] [fichier "tableau16.htm"] [depuis "a16"] [jusqua "a2"] [rang 1] [cle 1]} 
