;3World Cup Seniors Formula - Teams
;Direct tableau with all places from 1 to 16 fenced
{[classe suite_tableaux]
 [critere_constitution classement_initial]
 [hasard_par_2 oui]
 [qualifies 0]
 [nom "A"]
 [nom_etendu "main tableau"]
 [nom_tableaux "tableau of ^1"]
 [origine1 "classement_initial 1-1000"]
 [cle 1]
}
{[classe suite_tableaux]
 [critere_constitution progression_naturelle]
 [hasard_par_2 non]
 [qualifies 0]
 [nom "B"]
 [cle 2]
 [nom_etendu "tableau for 9th place"]
 [nom_tableaux "tableau 9-16 of ^1"]
 [origine1 "battus-tableau a16"]
}
{[classe suite_tableaux]
 [critere_constitution progression_naturelle]
 [hasard_par_2 non]
 [qualifies 0]
 [nom "C"]
